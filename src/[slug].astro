---
import { getCollection, render } from "astro:content";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import Markdown from "@components/common/Markdown.astro";

export async function getStaticPaths() {
	const specEntries = await getCollection("spec");
	return specEntries.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const pageTitle = entry.data.title || "Página";
---

<MainGridLayout title={pageTitle} description={entry.data.description}>
	<div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<Markdown class="mt-2">
				<Content />
			</Markdown>
		</div>
	</div>
</MainGridLayout>