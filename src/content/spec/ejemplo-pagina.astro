---
import { getEntry, render } from "astro:content";
import Markdown from "@components/common/Markdown.astro";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const ejemploPagina = await getEntry("spec", "ejemplo-pagina");

if (!ejemploPagina) {
	throw new Error("Contenido de 'ejemplo-pagina' no encontrado");
}

const { Content } = await render(ejemploPagina);
---
<MainGridLayout title={ejemploPagina.data.title} description={ejemploPagina.data.description}>
    <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>